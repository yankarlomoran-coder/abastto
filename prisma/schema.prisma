generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  BUYER
  SUPPLIER
  ADMIN
}

enum IndustrySector {
  AGRICULTURA
  CONSTRUCCION
  ESTADO_GOBIERNO
  MANUFACTURA
  MEDICAL_SALUD
  RETAIL_COMERCIO
  SERVICIOS_PROFESIONALES
  TECNOLOGIA
  TRANSPORTE_LOGISTICA
  OTRO
}

// Departamentos de Guatemala
enum Location {
  ALTA_VERAPAZ
  BAJA_VERAPAZ
  CHIMALTENANGO
  CHIQUIMULA
  EL_PROGRESO
  ESCUINTLA
  GUATEMALA
  HUEHUETENANGO
  IZABAL
  JALAPA
  JUTIAPA
  PETEN
  QUETZALTENANGO
  QUICHE
  RETALHULEU
  SACATEPEQUEZ
  SAN_MARCOS
  SANTA_ROSA
  SOLOLA
  SUCHITEPEQUEZ
  TOTONICAPAN
  ZACAPA
}

enum CompanyRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum RfqStatus {
  DRAFT_PENDING_APPROVAL
  OPEN
  EVALUATING
  CLOSED
  AWARDED
}

enum BidStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum PaymentTerms {
  CASH
  NET_30
  NET_60
}

enum RfqCategory {
  TECH
  OFFICE
  CONSTRUCTION
  SERVICES
  OTHER
}

model Company {
  id         String         @id @default(cuid())
  nit        String         @unique
  name       String
  industry   IndustrySector
  department Location
  isVerified Boolean        @default(false)
  kycStatus  String         @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  users           User[]
  rfqs            Rfq[]
  bids            Bid[]
  invitations     Invitation[]
  questions       Question[]
  authoredReviews Review[]     @relation("AuthoredReviews")
  receivedReviews Review[]     @relation("ReceivedReviews")
  documents       CompanyDocument[]
  sentMessages    Message[]    @relation("SentMessages")
  receivedMessages Message[]   @relation("ReceivedMessages")
}

model CompanyDocument {
  id        String   @id @default(cuid())
  type      String   // RTU, PATENTE, REPRESENTACION_LEGAL
  url       String   // Data URL for MVP or S3 URL
  status    String   @default("PENDING") // PENDING, APPROVED, REJECTED
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model User {
  id          String      @id @default(cuid())
  email       String      @unique
  password    String?
  name        String?
  role        Role        @default(BUYER)
  companyRole CompanyRole @default(OWNER)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id])
}

model Rfq {
  id               String        @id @default(cuid())
  title            String
  description      String
  budget           Decimal
  status           RfqStatus     @default(OPEN)
  needsApproval    Boolean       @default(false)
  approvedById     String?
  deadline         DateTime
  deliveryLocation String?
  paymentTerms     PaymentTerms?
  category         RfqCategory?
  aiAnalysis       String?       @db.Text
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  bids      Bid[]
  items     RfqItem[]
  questions Question[]
  reviews   Review[]
  messages  Message[]
}

model RfqItem {
  id       String @id @default(cuid())
  name     String
  quantity Int
  unit     String

  rfqId String
  rfq   Rfq    @relation(fields: [rfqId], references: [id], onDelete: Cascade)

  bidItems BidItem[]
}

model Bid {
  id               String    @id @default(cuid())
  amount           Decimal
  coverLetter      String
  status           BidStatus @default(PENDING)
  validityDays     Int?
  deliveryLeadTime String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  rfqId String
  rfq   Rfq    @relation(fields: [rfqId], references: [id], onDelete: Cascade)

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  items BidItem[]
}

model BidItem {
  id         String  @id @default(cuid())
  unitPrice  Decimal
  totalPrice Decimal
  remarks    String?

  bidId String
  bid   Bid    @relation(fields: [bidId], references: [id], onDelete: Cascade)

  rfqItemId String
  rfqItem   RfqItem @relation(fields: [rfqItemId], references: [id], onDelete: Cascade)
}

model Invitation {
  id        String      @id @default(uuid())
  email     String
  companyId String
  company   Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  role      CompanyRole
  token     String      @unique
  expiresAt DateTime
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@unique([email, companyId])
}

model Question {
  id        String   @id @default(cuid())
  content   String
  answer    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rfqId     String
  rfq       Rfq      @relation(fields: [rfqId], references: [id], onDelete: Cascade)

  companyId String // The company that asked the question
  company   Company  @relation(fields: [companyId], references: [id])
}

model Review {
  id                    String   @id @default(cuid())
  authorCompanyId       String
  targetCompanyId       String
  rfqId                 String

  ratingQuality         Int      // 1-5 (Producto/Claridad)
  ratingPunctuality     Int      // 1-5 (Entrega/Agilidad)
  ratingCommunication   Int      // 1-5 (Comunicación)
  ratingProfessionalism Int      // 1-5 (Profesionalismo/Resolución)
  comment               String?

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  authorCompany         Company  @relation("AuthoredReviews", fields: [authorCompanyId], references: [id])
  targetCompany         Company  @relation("ReceivedReviews", fields: [targetCompanyId], references: [id])
  rfq                   Rfq      @relation(fields: [rfqId], references: [id])

  // Una empresa solo puede dejar 1 reseña por RFQ
  @@unique([authorCompanyId, rfqId])
}

model Message {
  id         String   @id @default(cuid())
  content    String
  
  senderId   String
  receiverId String
  rfqId      String
  
  createdAt  DateTime @default(now())

  rfq        Rfq      @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  sender     Company  @relation("SentMessages", fields: [senderId], references: [id])
  receiver   Company  @relation("ReceivedMessages", fields: [receiverId], references: [id])
}


